{
    "@context":{
        "@vocab" : "https://schema.org/",
        "sosa" : "http://www.w3.org/ns/sosa/",
        "ssn" : "http://www.w3.org/ns/ssn/",
        "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
        "ssn-system": "http://www.w3.org/ns/ssn/systems/",
        "schema": "http://schema.org/",
        "qudt-unit-1-1": "http://qudt.org/vocab/unit#"
    },
    "@graph":[
    {
        "@id" : "urn:dev:team-01:rab-pi-01",
        "@type" : "ssn-System",
        "ssn:hasSubSystem" : {"@id" : "urn:dev:team-01:pir-01"},
        "rdfs:label" : "Raspberry Pi 5 running a debian based linux distro connected with the sensor using its GPIO pins, speciffically pin 17"
    },
    {
        "@id" : "urn:dev:team-01:pir-01",
        "@type" : ["sosa:Sensor","ssn:System"],
        "sosa:observes" : {"@id" : "urn:obs:property"},
        "rdfs:label" : "PIR HC-SR501",
        "ssn-system:hasSystemCapability": {"@id" : "urn:system:capabilities"},
        "ssn-system:hasOperatingRange" : {"@id" : "urn:system:opRange"}
    },
    {
        "@id" : "urn:obs:motion",
        "@type" : "sosa:Observation",
        "sosa:madeBySensor" : {"@id":"urn:dev:team-01:pir-01"},
        "sosa:observedProperty": {"@id" : "urn:obs:property"},
        "sosa:hasFeatureOfInterest" : {"@id":"urn:dev:team-01:wastebin-01"},
        "rdfs:label" : "It observes motion"
    },
    {
        "@id" : "urn:obs:property",
        "@type" : "sosa:ObservableProperty",
        "rdfs:label" : "It detects the passive infared heat emmited from warm bodies"
    },
    {
        "@id" : "urn:system:WorkingConditions",
        "@type" : "ssn-system:Condition",
        "schema:minValue" : -15.0,
        "schema:maxValue" : 70.0,
        "schema:unitCode:qudt-unit-1-1":"DegreeCelsius",
        "rdfs:label" : "Temperature range for working conditions"
    },
    {
        "@id" : "urn:system:capabilities",
        "@type" : "ssn-system:SystemCapability",
        "ssn-system:inCondition" : {"@id" : "urn:system:WorkingConditions"},
        "ssn-system:hasSystemProperty" : [{"@id" : "urn:system:frequency"},{"@id" : "urn:system:mesRange"},{"@id":"urn:system:detectionRange"},{"@id":"urn:system:detectionAngle"}]
    },
    {
        "@id" : "urn:system:mesRange",
        "@type" : "ssn-system:MeasurementRange",
        "schema:value" : [true,false],
        "rdfs:label" : "Sensor output (Bool)"
    },
    {
        "@id" : "urn:system:frequency",
        "@type" : "ssn-system:Frequency",
        "schema:value" : 0.5,
        "schema:unitCode:qudt-unit-1-1" : "Second",
        "rdfs:label" : ""
    },
    {
        "@id" : "urn:system:detectionRange",
        "@type" : "ssn-system:SystemProperty",
        "schema:minValue" : 0,
        "schema:maxValue" : 7,
        "schema:unitCode:qudt-unit-1-1" : "Meter"
    },
    {
        "@id" : "urn:system:detectionAngle",
        "@type" : "ssn-system:SystemProperty",
        "schema:minValue" : 0,
        "schema:maxValue" : 120,
        "schema:unitCode:qudt-unit-1-1" : "Degree"
    },
    {
        "@id" : "urn:system:opRange",
        "@type" : "ssn-system:OperatingRange",
        "ssn-system:inCondition" : {"@id" : "urn:system:WorkingConditions"},
        "ssn-system:hasOperatingProperty" : {"@id" : "urn:system:powerRange"}
    },
    {
        "@id" : "urn:system:powerRange",
        "@type" : "ssn-system:OperatingPowerRange",
        "schema:minValue" : 5,
        "schema:maxValue" : 20,
        "schema:unitCode":"qudt-unit-1-1:Volt"
    },
    {
        "@id" : "urn:team:deployment",
        "@type" : "tean:deployment",
        "deployment:mountedOn" : {"@id" : "urn:dev:team-01:wastebin-01"},
        "deployment:deployedIn" : {"@id" : "urn:env:team-01:site-01"}
    },
    {
        "@id" : "urn:team:status",
        "@type" : "team:status",
        "status:currentStatus" : "Active",
        "status:installationDate" : "Kapote"
    }
    ]}